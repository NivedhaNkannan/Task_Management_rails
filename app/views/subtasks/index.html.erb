<h1>View subtask</h1>



<table border="1">
  <tr>
    <th>ID</th>
    <th>Name</th>
    <th>Description</th>
    <th>Due Date</th>
    <th>Category</th>
    <th>Priority</th>
  </tr>

  <% @subtasks.each do |subtask| %>
    <tr>
      <td><%= subtask.id %></td>
      <td><%= subtask.name %></td>
      <td><%= subtask.description %></td>
      <td><%= subtask.due_date %></td>
      <td><%= subtask.category %></td>
      <td><%= subtask.priority %></td>
    </tr>
  <% end %>
</table>

<br>

<%= link_to "Add Subtask", new_taskn_subtask_path(@taskn) %>
